<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ .PageTitle }}</title>
    <style>
        :root {
            color-scheme: dark;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #1c1b19;
            color: #eae8e4;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.8;
        }

        a {
            color: #5ebaa8;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .shell {
            max-width: 54rem;
            margin: 0 auto;
            padding: 4rem 1.5rem 5rem;
        }

        .site-header {
            margin-bottom: 3.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid rgba(232, 232, 232, 0.12);
        }

        .site-title {
            margin: 0;
            font-size: clamp(2rem, 4vw, 2.6rem);
            line-height: 1.1;
        }

        .site-title a {
            color: inherit;
        }

        .site-tagline {
            margin: 0.6rem 0 0;
            color: #b8b5b0;
            font-size: 1rem;
        }

        .projects {
            margin-top: 1.25rem;
            interpolate-size: allow-keywords;
        }

        .projects summary {
            cursor: pointer;
            color: #a8a5a0;
            font-size: 0.88rem;
            list-style: none;
        }

        .projects summary::-webkit-details-marker {
            display: none;
        }

        .projects summary::after {
            content: " +";
        }

        .projects[open] summary::after {
            content: " \2212";
        }

        .projects::details-content {
            height: 0;
            overflow: clip;
            transition: height 0.15s ease-in-out, content-visibility 0.15s ease-in-out allow-discrete;
        }

        .projects[open]::details-content {
            height: auto;
        }

        @starting-style {
            .projects[open]::details-content {
                height: 0;
            }
        }

        .projects-links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.75rem;
        }

        .projects-links a {
            padding: 0.3rem 0.75rem;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.4rem;
            font-size: 0.88rem;
            color: #c5c3be;
        }

        .projects-links a:hover {
            background: rgba(94, 186, 168, 0.12);
            color: #5ebaa8;
            text-decoration: none;
        }

        .posts-title {
            margin: 0 0 2rem;
            font-size: 1.1rem;
            color: #cbc9c4;
        }

        .post-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: grid;
            gap: 3rem;
        }

        .post-list li {
            padding-bottom: 3rem;
            border-bottom: 1px solid rgba(232, 232, 232, 0.08);
        }

        .post-list li:last-child {
            border-bottom: 0;
            padding-bottom: 0;
        }

        .post-date {
            margin: 0 0 0.6rem;
            font-size: 0.95rem;
            color: #a8a5a0;
        }

        .post-link {
            display: inline-block;
            margin: 0 0 0.8rem;
            color: #eae8e4;
            font-size: clamp(1.4rem, 3vw, 1.8rem);
            line-height: 1.15;
        }

        .post-link:hover {
            color: #5ebaa8;
            text-decoration: none;
        }

        .post-excerpt {
            margin: 0;
            color: #c5c3be;
        }

        .empty-state {
            color: #b8b5b0;
        }

        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            margin-top: 4rem;
            font-size: 0.98rem;
        }

        .pagination-spacer {
            visibility: hidden;
        }

        .site-footer {
            margin-top: 5rem;
            color: #9a9894;
            font-size: 0.95rem;
        }

        @media (max-width: 640px) {
            .shell {
                padding-top: 2rem;
            }

            .site-header {
                margin-bottom: 2.25rem;
            }
        }
    </style>
</head>
<body>
    {{ .Marker }}
    <main class="shell">
        <header class="site-header">
            <h1 class="site-title"><a href="/">Jesse Young</a></h1>
            <p class="site-tagline">Notes on projects, software, and whatever earns a place on the homepage.</p>
            <details class="projects">
                <summary>Projects</summary>
                <nav class="projects-links" aria-label="Projects">
                    <a href="/mathsite/">Math Adventures</a>
                    <a href="/waveform-viz/">Waveform</a>
                </nav>
            </details>
        </header>

        <section aria-labelledby="posts-heading">
            <h2 id="posts-heading" class="posts-title">Posts</h2>
            {{ if .Posts }}
            <ol class="post-list">
                {{ range .Posts }}
                <li>
                    <p class="post-date">{{ .DisplayDate }}</p>
                    <a class="post-link" href="/p/{{ .Slug }}/">{{ .Title }}</a>
                    <p class="post-excerpt">{{ .Excerpt }}</p>
                </li>
                {{ end }}
            </ol>
            {{ else }}
            <p class="empty-state">No posts yet.</p>
            {{ end }}
        </section>

        <nav class="pagination" aria-label="Pagination">
            {{ if .NewerPageURL }}
            <a href="{{ .NewerPageURL }}">Newer posts</a>
            {{ else }}
            <span class="pagination-spacer">Newer posts</span>
            {{ end }}

            {{ if .OlderPageURL }}
            <a href="{{ .OlderPageURL }}">Older posts</a>
            {{ else }}
            <span class="pagination-spacer">Older posts</span>
            {{ end }}
        </nav>

        <footer class="site-footer">
            <p>Jesse Young / EMAIL HERE / LINK 1 / LINK 2</p>
        </footer>
    </main>
</body>
</html>
