<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ .PageTitle }}</title>
    <style>
        :root {
            color-scheme: dark;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #1a1a1a;
            color: #e8e8e8;
            font-family: Georgia, "Times New Roman", serif;
            line-height: 1.7;
        }

        a {
            color: #5599ff;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .shell {
            max-width: 44rem;
            margin: 0 auto;
            padding: 3rem 1rem 4rem;
        }

        .site-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 1rem 2rem;
            align-items: flex-end;
            margin-bottom: 3rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid rgba(232, 232, 232, 0.12);
        }

        .site-title {
            margin: 0;
            font-size: clamp(2rem, 4vw, 2.6rem);
            line-height: 1.1;
        }

        .site-title a {
            color: inherit;
        }

        .site-tagline {
            margin: 0.4rem 0 0;
            color: #bdbdbd;
            font-size: 1rem;
        }

        .projects-title {
            margin: 0 0 0.35rem;
            color: #9e9e9e;
            font-size: 0.85rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .projects-links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.85rem;
        }

        .posts-title {
            margin: 0 0 1.5rem;
            font-size: 1.1rem;
            color: #cfcfcf;
        }

        .post-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: grid;
            gap: 2.4rem;
        }

        .post-list li {
            padding-bottom: 2.4rem;
            border-bottom: 1px solid rgba(232, 232, 232, 0.08);
        }

        .post-list li:last-child {
            border-bottom: 0;
            padding-bottom: 0;
        }

        .post-date {
            margin: 0 0 0.45rem;
            font-size: 0.95rem;
            color: #ababab;
        }

        .post-link {
            display: inline-block;
            margin: 0 0 0.65rem;
            color: #e8e8e8;
            font-size: clamp(1.4rem, 3vw, 1.8rem);
            line-height: 1.15;
        }

        .post-link:hover {
            color: #5599ff;
            text-decoration: none;
        }

        .post-excerpt {
            margin: 0;
            color: #c9c9c9;
        }

        .empty-state {
            color: #bdbdbd;
        }

        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            margin-top: 3rem;
            font-size: 0.98rem;
        }

        .pagination-spacer {
            visibility: hidden;
        }

        .site-footer {
            margin-top: 4rem;
            color: #9c9c9c;
            font-size: 0.95rem;
        }

        @media (max-width: 640px) {
            .shell {
                padding-top: 2rem;
            }

            .site-header {
                margin-bottom: 2.25rem;
            }
        }
    </style>
</head>
<body>
    {{ .Marker }}
    <main class="shell">
        <header class="site-header">
            <div>
                <h1 class="site-title"><a href="/">Jesse Young</a></h1>
                <p class="site-tagline">Notes on projects, software, and whatever earns a place on the homepage.</p>
            </div>
            <nav aria-label="Projects">
                <p class="projects-title">Projects</p>
                <div class="projects-links">
                    <a href="/mathsite/">Math Adventures</a>
                    <a href="/waveform-viz/">Waveform</a>
                </div>
            </nav>
        </header>

        <section aria-labelledby="posts-heading">
            <h2 id="posts-heading" class="posts-title">Posts</h2>
            {{ if .Posts }}
            <ol class="post-list">
                {{ range .Posts }}
                <li>
                    <p class="post-date">{{ .DisplayDate }}</p>
                    <a class="post-link" href="/{{ .Slug }}/">{{ .Title }}</a>
                    <p class="post-excerpt">{{ .Excerpt }}</p>
                </li>
                {{ end }}
            </ol>
            {{ else }}
            <p class="empty-state">No posts yet.</p>
            {{ end }}
        </section>

        <nav class="pagination" aria-label="Pagination">
            {{ if .NewerPageURL }}
            <a href="{{ .NewerPageURL }}">Newer posts</a>
            {{ else }}
            <span class="pagination-spacer">Newer posts</span>
            {{ end }}

            {{ if .OlderPageURL }}
            <a href="{{ .OlderPageURL }}">Older posts</a>
            {{ else }}
            <span class="pagination-spacer">Older posts</span>
            {{ end }}
        </nav>

        <footer class="site-footer">
            <p>Built without JavaScript. Written in markdown. Rendered by a small Go program.</p>
        </footer>
    </main>
</body>
</html>
