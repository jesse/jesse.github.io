<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ .Title }} | Jesse Young</title>
    <style>
        :root {
            color-scheme: dark;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #1c1b19;
            color: #eae8e4;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.8;
        }

        a {
            color: #5ebaa8;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .shell {
            max-width: 54rem;
            margin: 0 auto;
            padding: 4rem 1.5rem 5rem;
        }

        .site-header {
            margin-bottom: 3rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid rgba(232, 232, 232, 0.12);
        }

        .site-title {
            margin: 0;
            font-size: 1.9rem;
            line-height: 1.1;
        }

        .site-title a {
            color: inherit;
        }

        .site-tagline {
            margin: 0.6rem 0 0;
            color: #b8b5b0;
            font-size: 1rem;
        }

        .projects {
            margin-top: 1.25rem;
            interpolate-size: allow-keywords;
        }

        .projects summary {
            cursor: pointer;
            color: #a8a5a0;
            font-size: 0.88rem;
            list-style: none;
        }

        .projects summary::-webkit-details-marker {
            display: none;
        }

        .projects summary::after {
            content: " +";
        }

        .projects[open] summary::after {
            content: " \2212";
        }

        .projects::details-content {
            height: 0;
            overflow: clip;
            transition: height 0.15s ease-in-out, content-visibility 0.15s ease-in-out allow-discrete;
        }

        .projects[open]::details-content {
            height: auto;
        }

        @starting-style {
            .projects[open]::details-content {
                height: 0;
            }
        }

        .projects-links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.75rem;
        }

        .projects-links a {
            padding: 0.3rem 0.75rem;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.4rem;
            font-size: 0.88rem;
            color: #c5c3be;
        }

        .projects-links a:hover {
            background: rgba(94, 186, 168, 0.12);
            color: #5ebaa8;
            text-decoration: none;
        }

        .post-date {
            margin: 0 0 0.75rem;
            color: #a8a5a0;
            font-size: 0.98rem;
        }

        h1 {
            margin: 0 0 2.5rem;
            font-size: clamp(2.2rem, 5vw, 3.3rem);
            line-height: 1.05;
        }

        .prose {
            font-size: 1.08rem;
        }

        .prose > *:first-child {
            margin-top: 0;
        }

        .prose p,
        .prose ul,
        .prose ol {
            margin: 1.5rem 0;
        }

        .prose ul,
        .prose ol {
            padding-left: 1.5rem;
        }

        .prose li + li {
            margin-top: 0.6rem;
        }

        .prose blockquote {
            margin: 2.5rem 0;
            padding: 1.1rem 1.2rem 1.1rem 1.35rem;
            border-left: 4px solid #5ebaa8;
            background: rgba(94, 186, 168, 0.08);
            color: #c2ddd5;
            border-radius: 0.85rem;
        }

        .prose blockquote > *:first-child {
            margin-top: 0;
        }

        .prose blockquote > *:last-child {
            margin-bottom: 0;
        }

        .prose img {
            display: block;
            max-width: 100%;
            height: auto;
            margin: 2.25rem auto;
            border-radius: 1rem;
            background: #232220;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.3);
        }

        .prose p code,
        .prose li code,
        .prose blockquote code {
            padding: 0.15rem 0.35rem;
            border-radius: 0.4rem;
            background: rgba(255, 255, 255, 0.08);
            font-family: "SFMono-Regular", SFMono-Regular, Consolas, "Liberation Mono", Menlo, monospace;
            font-size: 0.92em;
        }

        .prose .highlight,
        .prose .plain-code {
            width: min(72rem, calc(100vw - 2rem));
            max-width: 72rem;
            margin: 2.25rem 50%;
            transform: translateX(-50%);
        }

        .prose .highlight > pre,
        .prose .plain-code > pre {
            margin: 0;
            padding: 1.5rem 1.5rem 1.5rem 2.5rem;
            white-space: pre-wrap;
            overflow-wrap: break-word;
            background: #141311;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 1rem;
            font-family: "SFMono-Regular", SFMono-Regular, Consolas, "Liberation Mono", Menlo, monospace;
            font-size: 0.92rem;
            line-height: 1.55;
        }

        .prose .highlight code,
        .prose .plain-code code {
            font-family: inherit;
        }

        .back-link {
            margin-top: 3.5rem;
        }

        .site-footer {
            margin-top: 5rem;
            color: #9a9894;
            font-size: 0.95rem;
        }

        @media (max-width: 640px) {
            .shell {
                padding-top: 2rem;
            }

            .prose {
                font-size: 1rem;
            }
        }

        {{ .ChromaCSS }}
    </style>
</head>
<body>
    {{ .Marker }}
    <main class="shell">
        <header class="site-header">
            <p class="site-title"><a href="/">Jesse Young</a></p>
            <p class="site-tagline">Notes on projects, software, and whatever earns a place on the homepage.</p>
            <details class="projects">
                <summary>Projects</summary>
                <nav class="projects-links" aria-label="Projects">
                    <a href="/mathsite/">Math Adventures</a>
                    <a href="/waveform-viz/">Waveform</a>
                </nav>
            </details>
        </header>

        <article class="prose">
            <p class="post-date">{{ .DisplayDate }}</p>
            <h1>{{ .Title }}</h1>
            {{ .Content }}
            <p class="back-link"><a href="/">Back to all posts</a></p>
        </article>

        <footer class="site-footer">
            <p>Built without JavaScript. Written in markdown. Rendered by a small Go program.</p>
        </footer>
    </main>
</body>
</html>
