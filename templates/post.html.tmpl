<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ .Title }} | Jesse Young</title>
    <style>
        :root {
            color-scheme: dark;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #1a1a1a;
            color: #e8e8e8;
            font-family: Georgia, "Times New Roman", serif;
            line-height: 1.7;
        }

        a {
            color: #5599ff;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .shell {
            max-width: 44rem;
            margin: 0 auto;
            padding: 3rem 1rem 4rem;
        }

        .site-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 1rem 2rem;
            align-items: flex-end;
            margin-bottom: 2.5rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid rgba(232, 232, 232, 0.12);
        }

        .site-title {
            margin: 0;
            font-size: 1.9rem;
            line-height: 1.1;
        }

        .site-title a {
            color: inherit;
        }

        .site-tagline {
            margin: 0.4rem 0 0;
            color: #bdbdbd;
            font-size: 1rem;
        }

        .projects-title {
            margin: 0 0 0.35rem;
            color: #9e9e9e;
            font-size: 0.85rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .projects-links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.85rem;
        }

        .post-date {
            margin: 0 0 0.5rem;
            color: #ababab;
            font-size: 0.98rem;
        }

        h1 {
            margin: 0 0 2rem;
            font-size: clamp(2.2rem, 5vw, 3.3rem);
            line-height: 1.05;
        }

        .prose {
            font-size: 1.08rem;
        }

        .prose > *:first-child {
            margin-top: 0;
        }

        .prose p,
        .prose ul,
        .prose ol {
            margin: 1.2rem 0;
        }

        .prose ul,
        .prose ol {
            padding-left: 1.5rem;
        }

        .prose li + li {
            margin-top: 0.45rem;
        }

        .prose blockquote {
            margin: 2rem 0;
            padding: 1.1rem 1.2rem 1.1rem 1.35rem;
            border-left: 4px solid #5599ff;
            background: rgba(85, 153, 255, 0.08);
            color: #c9d7f2;
            border-radius: 0.85rem;
        }

        .prose blockquote > *:first-child {
            margin-top: 0;
        }

        .prose blockquote > *:last-child {
            margin-bottom: 0;
        }

        .prose img {
            display: block;
            max-width: 100%;
            height: auto;
            margin: 1.75rem auto;
            border-radius: 1rem;
            background: #232323;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.3);
        }

        .prose p code,
        .prose li code,
        .prose blockquote code {
            padding: 0.15rem 0.35rem;
            border-radius: 0.4rem;
            background: rgba(255, 255, 255, 0.08);
            font-family: "SFMono-Regular", SFMono-Regular, Consolas, "Liberation Mono", Menlo, monospace;
            font-size: 0.92em;
        }

        .prose .highlight,
        .prose .plain-code {
            width: min(72rem, calc(100vw - 2rem));
            max-width: 72rem;
            margin: 1.75rem 50%;
            transform: translateX(-50%);
        }

        .prose .highlight > pre,
        .prose .plain-code > pre {
            margin: 0;
            padding: 1rem 1.15rem;
            overflow-x: auto;
            white-space: pre;
            background: #111317;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 1rem;
            font-family: "SFMono-Regular", SFMono-Regular, Consolas, "Liberation Mono", Menlo, monospace;
            font-size: 0.92rem;
            line-height: 1.55;
        }

        .prose .highlight code,
        .prose .plain-code code {
            font-family: inherit;
        }

        .back-link {
            margin-top: 2.5rem;
        }

        .site-footer {
            margin-top: 4rem;
            color: #9c9c9c;
            font-size: 0.95rem;
        }

        @media (max-width: 640px) {
            .shell {
                padding-top: 2rem;
            }

            .prose {
                font-size: 1rem;
            }
        }

        {{ .ChromaCSS }}
    </style>
</head>
<body>
    {{ .Marker }}
    <main class="shell">
        <header class="site-header">
            <div>
                <p class="site-title"><a href="/">Jesse Young</a></p>
                <p class="site-tagline">Notes on projects, software, and whatever earns a place on the homepage.</p>
            </div>
            <nav aria-label="Projects">
                <p class="projects-title">Projects</p>
                <div class="projects-links">
                    <a href="/mathsite/">Math Adventures</a>
                    <a href="/waveform-viz/">Waveform</a>
                </div>
            </nav>
        </header>

        <article class="prose">
            <p class="post-date">{{ .DisplayDate }}</p>
            <h1>{{ .Title }}</h1>
            {{ .Content }}
            <p class="back-link"><a href="/">Back to all posts</a></p>
        </article>

        <footer class="site-footer">
            <p>Built without JavaScript. Written in markdown. Rendered by a small Go program.</p>
        </footer>
    </main>
</body>
</html>
